/** @var Mage_Install_Block_Progress $this */
?>
<div class="progress-stepper">
    <h2><?= $this->__('Installation Progress') ?></h2>
    <ol class="stepper-list">
        <?php
        $stepNumber = 0;
        $activeFound = false;
        foreach ($steps as $_step):
            $stepNumber++;
            $isActive = $_step->getActive();
            $isCompleted = !$activeFound && !$isActive;
            if ($isActive) {
                $activeFound = true;
            }
            $classes = ['stepper-item'];
            if ($isCompleted) {
                $classes[] = 'completed';
            }
            if ($isActive) {
                $classes[] = 'active';
            }
        ?>
        <li class="<?= implode(' ', $classes) ?>" data-step="<?= $stepNumber ?>">
            <div class="stepper-circle" aria-label="Step <?= $stepNumber ?>"></div>
            <span class="stepper-label"><?= $this->__($_step->getCode()) ?></span>
        </li>
        <?php endforeach ?>
    </ol>
</div>
