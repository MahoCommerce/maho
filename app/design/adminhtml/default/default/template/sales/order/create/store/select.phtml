<?php /** @var Mage_Adminhtml_Block_Sales_Order_Create_Store_Select $this */ ?>
<?php
// Build the hierarchy first, skipping empty websites/groups. Whether the website
// and store-group names are shown (hidden when there's only one) is handled in CSS.
$_websites = [];
foreach ($this->getWebsiteCollection() as $_website) {
    $_groups = [];
    foreach ($this->getGroupCollection($_website) as $_group) {
        $_stores = $this->getStoreCollection($_group);
        if (count($_stores) > 0) {
            $_groups[] = [$_group, $_stores];
        }
    }
    if (count($_groups) > 0) {
        $_websites[] = [$_website, $_groups];
    }
}
?>
<div class="store-scope order-store-select">
<?php foreach ($_websites as [$_website, $_groups]): ?>
    <div class="store-website">
        <h3 class="store-website-name"><?= $this->escapeHtml($_website->getName()) ?></h3>
        <?php foreach ($_groups as [$_group, $_stores]): ?>
            <div class="store-group">
                <h4 class="store-group-name"><?= $this->escapeHtml($_group->getName()) ?></h4>
                <div class="store-view-cards">
                    <?php foreach ($_stores as $_store): ?>
                        <label class="store-view-card" for="store_<?= $_store->getId() ?>">
                            <input type="radio" name="store_select" id="store_<?= $_store->getId() ?>" class="radio" onclick="order.setStoreId('<?= $_store->getId() ?>')">
                            <span class="store-view-name"><?= $this->escapeHtml($_store->getName()) ?></span>
                        </label>
                    <?php endforeach ?>
                </div>
            </div>
        <?php endforeach ?>
    </div>
<?php endforeach ?>
</div>
