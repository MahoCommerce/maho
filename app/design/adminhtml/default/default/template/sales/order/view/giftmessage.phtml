?>
<?php if($this->canDisplayGiftmessage()): ?>
<?php $_required = $this->getMessage()->getMessage() != ''?>
<div id="<?= $this->getHtmlId() ?>" class="box-left giftmessage-whole-order-container">
    <div class="entry-edit">
        <div><?= Mage::helper('sales')->__('Gift Message for the Entire Order') ?></div><br>
        <form id="<?= $this->getFieldId('form') ?>" action="<?= $this->getSaveUrl() ?>">
          <fieldset>
              <input type="hidden" id="<?= $this->getFieldId('type') ?>" name="<?= $this->getFieldName('type') ?>" value="order">
              <table width="100%" cellspacing="0">
                <tbody>
                  <tr>
                      <td class="label"><label><?= Mage::helper('sales')->__('From Name') ?><?= $_required ? '&nbsp;<span class="required">*</span>' : '' ?></label></td>
                      <td class="input-ele"><input class="input-text" type="text" id="<?= $this->getFieldId('sender') ?>" name="<?= $this->getFieldName('sender') ?>" value="<?= $this->escapeHtml($this->getMessage()->getSender()) ?>"></td>
