$opcache = $this->getOpcacheStatus();
$extensions = $this->getPhpExtensions();
$checks = $this->getHealthChecks();
?>

<style>
    .healthcheck-grid {
        display: grid;
        gap: 20px;
        margin-bottom: 20px;
    }
    .healthcheck-row-3 {
        grid-template-columns: 1fr 1fr 1fr;
    }
    .healthcheck-row-2 {
        grid-template-columns: 1fr 1fr;
    }
    .healthcheck-section {
        background: #fff;
        border: 1px solid #d6d6d6;
        border-radius: 4px;
    }
    .healthcheck-section h3 {
        margin: 0;
        padding: 10px 15px;
        background: #f5f5f5;
        border-bottom: 1px solid #d6d6d6;
        font-size: 13px;
    }
    .healthcheck-section table {
        width: 100%;
        border-collapse: collapse;
    }
    .healthcheck-section table td {
        padding: 6px 15px;
        border-bottom: 1px solid #ededed;
        font-size: 12px;
        vertical-align: top;
    }
    .healthcheck-section table tr:last-child td {
        border-bottom: none;
    }
    .healthcheck-section table td:first-child {
        font-weight: 600;
        width: 45%;
        color: #555;
    }
    .ext-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 4px;
        padding: 10px 15px;
    }
    .ext-item {
        font-size: 12px;
        padding: 3px 8px;
        border-radius: 3px;
    }
    .ext-ok { background: #e6f9e6; color: #2a7a2a; }
    .ext-missing { background: #fce4e4; color: #c00; }
    .check-ok { color: #2a7a2a; }
    .check-warning { color: #e68a00; }
    .check-error { color: #c00; }
</style>

<div class="content-header">
