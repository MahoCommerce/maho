</div>

<div class="healthcheck-grid healthcheck-row-2">
    <div class="healthcheck-section">
        <h3><?= $this->__('PHP') ?></h3>
        <table>
            <tr>
                <td><?= $this->__('Version') ?></td>
                <td><?= $this->escapeHtml($this->getPhpVersion()) ?></td>
            </tr>
            <tr>
                <td><?= $this->__('SAPI') ?></td>
                <td><?= $this->escapeHtml($this->getPhpSapi()) ?></td>
            </tr>
            <tr>
                <td><?= $this->__('Memory Limit') ?></td>
                <td><?= $this->escapeHtml($this->getPhpMemoryLimit()) ?></td>
            </tr>
            <tr>
                <td><?= $this->__('Max Execution Time') ?></td>
                <td><?= $this->escapeHtml($this->getPhpMaxExecutionTime()) ?>s</td>
            </tr>
            <tr>
                <td><?= $this->__('Max Input Vars') ?></td>
                <td><?= $this->escapeHtml($this->getPhpMaxInputVars()) ?></td>
            </tr>
            <tr>
                <td><?= $this->__('Post Max Size') ?></td>
                <td><?= $this->escapeHtml($this->getPhpPostMaxSize()) ?></td>
            </tr>
            <tr>
                <td><?= $this->__('Upload Max Filesize') ?></td>
                <td><?= $this->escapeHtml($this->getPhpUploadMaxFilesize()) ?></td>
            </tr>
        </table>
    </div>

    <?php if ($opcache !== null): ?>
    <div class="healthcheck-section">
        <h3><?= $this->__('OPcache') ?></h3>
        <table>
            <tr>
                <td><?= $this->__('Status') ?></td>
                <td class="<?= $opcache['enabled'] ? 'check-ok' : 'check-warning' ?>">
                    <?= $opcache['enabled'] ? $this->__('Enabled') : $this->__('Disabled') ?>
                </td>
            </tr>
            <?php if ($opcache['enabled']): ?>
            <tr>
                <td><?= $this->__('Memory') ?></td>
                <td><?= $this->escapeHtml($opcache['memory_used'] . ' / ' . $opcache['memory_total']) ?> (<?= $this->escapeHtml($opcache['memory_free']) ?> <?= $this->__('free') ?>)</td>
            </tr>
            <tr>
                <td><?= $this->__('Wasted Memory') ?></td>
                <td><?= $this->escapeHtml($opcache['memory_wasted'] . ' (' . $opcache['memory_wasted_pct'] . ')') ?></td>
            </tr>
            <tr>
                <td><?= $this->__('Hit Rate') ?></td>
                <td><?= $this->escapeHtml($opcache['hit_rate']) ?> (<?= number_format($opcache['hits']) ?> <?= $this->__('hits') ?> / <?= number_format($opcache['misses']) ?> <?= $this->__('misses') ?>)</td>
            </tr>
            <tr>
                <td><?= $this->__('Cached Scripts') ?></td>
                <td><?= $opcache['cached_scripts'] ?><?php if ($opcache['max_cached_scripts']): ?> / <?= $opcache['max_cached_scripts'] ?><?php endif ?></td>
            </tr>
            <tr>
                <td><?= $this->__('Cached Keys') ?></td>
                <td><?= number_format($opcache['cached_keys']) ?><?php if ($opcache['max_cached_keys']): ?> / <?= number_format($opcache['max_cached_keys']) ?><?php endif ?></td>
            </tr>
            <?php if ($opcache['interned_strings_used']): ?>
            <tr>
                <td><?= $this->__('Interned Strings') ?></td>
                <td><?= $this->escapeHtml($opcache['interned_strings_used']) ?> <?= $this->__('used') ?> / <?= $this->escapeHtml($opcache['interned_strings_free']) ?> <?= $this->__('free') ?> (<?= number_format($opcache['interned_strings_count']) ?> <?= $this->__('strings') ?>)</td>
            </tr>
            <?php endif ?>
            <tr>
                <td><?= $this->__('JIT') ?></td>
                <td class="<?= $opcache['jit_enabled'] ? 'check-ok' : '' ?>">
                    <?= $opcache['jit_enabled'] ? $this->__('Enabled') : $this->__('Disabled') ?>
                    <?php if (isset($opcache['jit_buffer_size'])): ?>
                        (<?= $this->escapeHtml($opcache['jit_buffer_size']) ?>)
                    <?php endif ?>
                </td>
            </tr>
            <?php if (!empty($opcache['directives'])): ?>
            <tr>
                <td colspan="2" style="padding: 0;">
                    <details>
                        <summary style="padding: 8px 15px; cursor: pointer; font-weight: 600; color: #555; user-select: none;"><?= $this->__('All Directives') ?></summary>
                        <table style="width: 100%;">
                            <?php foreach ($opcache['directives'] as $key => $value): ?>
                            <tr>
                                <td style="width: 45%; padding-left: 25px;"><?= $this->escapeHtml($key) ?></td>
                                <td><?php
                                    if (is_bool($value)) {
                                        echo $value ? 'true' : 'false';
                                    } elseif (is_int($value) && $value > 1048576 && str_contains($key, 'memory')) {
                                        echo $this->escapeHtml(round($value / 1048576) . ' MB (' . $value . ')');
                                    } else {
                                        echo $this->escapeHtml((string) $value);
                                    }
                                ?></td>
                            </tr>
                            <?php endforeach ?>
                        </table>
                    </details>
                </td>
            </tr>
            <?php endif ?>
            <?php endif ?>
        </table>
    </div>
    <?php endif ?>
</div>

<div class="healthcheck-grid healthcheck-row-2">
    <div class="healthcheck-section">
        <h3><?= $this->__('PHP Extensions') ?></h3>
        <div class="ext-grid">
            <?php foreach ($extensions as $name => $loaded): ?>
                <span class="ext-item <?= $loaded ? 'ext-ok' : 'ext-missing' ?>">
                    <?= $loaded ? '&#10003;' : '&#10007;' ?> <?= $this->escapeHtml($name) ?>
                </span>
            <?php endforeach ?>
        </div>
    </div>

    <div class="healthcheck-section">
        <h3><?= $this->__('Health Checks') ?></h3>
        <table>
            <?php foreach ($checks as $check): ?>
            <tr>
                <td><?= $this->escapeHtml($check['check']) ?></td>
                <td>
                    <span class="check-<?= $check['severity'] ?>">
                        <?= $this->escapeHtml($check['status']) ?>
                    </span>
                    <?php if ($check['details']): ?>
                        <br><small><?= $this->escapeHtml($check['details']) ?></small>
                    <?php endif ?>
                </td>
            </tr>
            <?php endforeach ?>
        </table>
    </div>
</div>
