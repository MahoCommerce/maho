            <tr>
                <td><?= $this->__('Version') ?></td>
                <td><?= $this->escapeHtml($this->getDatabaseVersion()) ?></td>
            </tr>
            <tr>
                <td><?= $this->__('Database Size') ?></td>
                <td><?= $this->escapeHtml($this->getDatabaseSize()) ?></td>
            </tr>
