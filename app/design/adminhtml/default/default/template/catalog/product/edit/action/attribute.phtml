/** @var Mage_Adminhtml_Block_Catalog_Product_Edit_Action_Attribute_Tab_Attributes $this */
?>
<div class="content-header">
    <h3><?= Mage::helper('catalog')->__('Update attributes') ?></h3>
    <p class="content-buttons form-buttons">
        <?= $this->getBackButtonHtml() ?>
        <?= $this->getCancelButtonHtml() ?>
        <?= $this->getSaveButtonHtml() ?>
    </p>
</div>
<form action="<?= $this->getSaveUrl() ?>" method="post" id="attributes_edit_form" enctype="multipart/form-data">
    <?= $this->getBlockHtml('formkey') ?>
</form>
<script>
var attributesForm = new varienForm('attributes_edit_form', '<?= $this->getValidationUrl() ?>');
attributesForm._processValidationResult = function(response) {

    if (response.error){
        if (response.attribute && document.getElementById(response.attribute)) {
            const attributeElement = document.getElementById(response.attribute);
            attributeElement.setHasError(true, attributesForm);
            Validation.ajaxError(attributeElement, response.message);
            attributeElement.focus();
        } else {
            const messagesEl = document.getElementById('messages');
            if (messagesEl) {
                messagesEl.textContent = '';
                const ul = document.createElement('ul');
                ul.className = 'messages';
                const li = document.createElement('li');
                li.className = 'error-msg';
                const innerUl = document.createElement('ul');
                const innerLi = document.createElement('li');
                innerLi.textContent = response.message;
                innerUl.appendChild(innerLi);
                li.appendChild(innerUl);
                ul.appendChild(li);
                messagesEl.appendChild(ul);
            }
        }
    } else {
        attributesForm._submit();
    }
};
</script>
