/** @var Maho_Revocation_Block_Adminhtml_Request_View $this */
$helper = Mage::helper('revocation');
$request = $this->getRevocationRequest();
if (!$request) {
    return;
}
$order = $request->getOrder();
?>
<div class="content-header">
    <h3 class="icon-head head-sales-order"><?= $this->escapeHtml($this->getHeaderText()) ?></h3>
    <p class="content-buttons form-buttons"><?= $this->getButtonsHtml() ?></p>
</div>

<?php if ($request->getSuppressedAt()): ?>
<ul class="messages">
    <li class="warning-msg">
        <ul>
            <li>
                <?= $helper->__('The customer receipt email was suppressed (%s) at %s and has not been delivered. Use "Resend Receipt Email" to deliver it after triage.', $this->escapeHtml((string) $request->getSuppressedReason()), $this->formatDateTime($request->getSuppressedAt())) ?>
            </li>
        </ul>
    </li>
</ul>
<?php endif ?>

<div class="entry-edit">
    <div class="entry-edit-head">
        <h4 class="icon-head"><?= $helper->__('Declaration (read-only legal record)') ?></h4>
    </div>
    <div class="fieldset">
        <table class="form-list" cellspacing="0">
            <tr>
                <td class="label"><?= $helper->__('Reference number') ?></td>
                <td class="value"><strong>#<?= (int) $request->getId() ?></strong></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('Received at (UTC)') ?></td>
                <td class="value"><?= $this->escapeHtml($request->getReceivedAt()) ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('Customer Name') ?></td>
                <td class="value"><?= $this->escapeHtml($request->getCustomerName()) ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('Email') ?></td>
                <td class="value"><?= $this->escapeHtml($request->getEmail()) ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('Order Reference') ?></td>
                <td class="value"><?= $this->escapeHtml($request->getOrderReference()) ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('Reason') ?></td>
                <td class="value"><?= $request->getReason() ? nl2br($this->escapeHtml($request->getReason())) : '<em>' . $helper->__('(none given, not required)') . '</em>' ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('Verified') ?></td>
                <td class="value"><?= $request->getVerified() ? $helper->__('Yes (submitted from an authenticated customer session)') : $helper->__('No (self-asserted via the public form)') ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('IP Address') ?></td>
                <td class="value"><?= $this->escapeHtml((string) $request->getIp()) ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('User Agent') ?></td>
                <td class="value"><?= $this->escapeHtml((string) $request->getUserAgent()) ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('Locale') ?></td>
                <td class="value"><?= $this->escapeHtml((string) $request->getLocale()) ?></td>
            </tr>
        </table>
    </div>
</div>

<div class="entry-edit">
    <div class="entry-edit-head">
        <h4 class="icon-head"><?= $helper->__('Matched Order') ?></h4>
    </div>
    <div class="fieldset">
        <?php if ($order): ?>
            <p>
                <?= $helper->__('Order') ?>
                <a href="<?= $this->getOrderViewUrl($order) ?>"><strong>#<?= $this->escapeHtml($order->getIncrementId()) ?></strong></a>
                (<?= $this->escapeHtml($order->getStatusLabel()) ?>)
            </p>
            <p class="note"><?= $helper->__('"Accept Revocation" applies the revocation_accepted order status and opens the credit memo page. "Reject Revocation" applies the revocation_rejected status. Neither changes the order state, and no refund happens automatically.') ?></p>
        <?php else: ?>
            <p><?= $helper->__('No order could be matched to this request. The customer typed "%s".', $this->escapeHtml($request->getOrderReference())) ?></p>
            <?php if ($this->getRevocationRequest() && Mage::getSingleton('admin/session')->isAllowed('sales/revocation/process')): ?>
            <form action="<?= $this->getLinkOrderUrl() ?>" method="post">
                <?= $this->getBlockHtml('formkey') ?>
                <label for="order_increment_id"><?= $helper->__('Link to order (increment ID):') ?></label>
                <input type="text" class="input-text" id="order_increment_id" name="order_increment_id" value="<?= $this->escapeHtml($request->getOrderReference()) ?>">
                <button type="submit" class="scalable"><span><span><span><?= $helper->__('Link Order') ?></span></span></span></button>
            </form>
            <?php endif ?>
        <?php endif ?>
    </div>
</div>

<div class="entry-edit">
    <div class="entry-edit-head">
        <h4 class="icon-head"><?= $helper->__('Processing') ?></h4>
    </div>
    <div class="fieldset">
        <table class="form-list" cellspacing="0">
            <tr>
                <td class="label"><?= $helper->__('Processed Status') ?></td>
                <td class="value"><?= $this->getProcessedStatusLabel() ?: '<em>' . $helper->__('(not processed yet)') . '</em>' ?></td>
            </tr>
            <tr>
                <td class="label"><?= $helper->__('Processed At') ?></td>
                <td class="value"><?= $this->formatDateTime($request->getProcessedAt()) ?></td>
            </tr>
        </table>
        <form action="<?= $this->getSaveUrl() ?>" method="post" id="revocation-note-form">
            <?= $this->getBlockHtml('formkey') ?>
            <label for="admin_note"><?= $helper->__('Internal Note') ?></label><br>
            <textarea name="admin_note" id="admin_note" class="input-text" style="width:600px;" rows="5"><?= $this->escapeHtml((string) $request->getAdminNote()) ?></textarea><br>
            <button type="submit" class="scalable save"><span><span><span><?= $helper->__('Save Note') ?></span></span></span></button>
        </form>
    </div>
</div>

<form action="<?= $this->getProcessUrl() ?>" method="post" id="revocation-process-form">
    <?= $this->getBlockHtml('formkey') ?>
    <input type="hidden" name="decision" value="" id="revocation-process-decision">
</form>
<script>
    const revocationProcess = {
        submit(decision) {
            const messages = {
                accept: '<?= $this->jsQuoteEscape($helper->__('Accept this revocation? The matched order (if any) will be set to the revocation_accepted status.')) ?>',
                reject: '<?= $this->jsQuoteEscape($helper->__('Reject this revocation? The matched order (if any) will be set to the revocation_rejected status.')) ?>'
            };
            if (confirm(messages[decision])) {
                document.getElementById('revocation-process-decision').value = decision;
                document.getElementById('revocation-process-form').submit();
            }
        }
    };
</script>
