/** @var Maho_Paypal_Block_Checkout_Advanced_Form $this */
$methodCode = $this->getMethodCode();
?>
<div id="payment_form_<?= $this->escapeHtml($methodCode) ?>" style="display:none"
    data-sdk-url="<?= $this->escapeUrl($this->getJsSdkUrl()) ?>"
    data-client-token-url="<?= $this->escapeUrl($this->getClientTokenUrl()) ?>"
    data-currency-code="<?= $this->escapeHtml($this->getCurrencyCode()) ?>"
    data-create-order-url="<?= $this->escapeUrl($this->getCreateOrderUrl()) ?>"
    data-approve-order-url="<?= $this->escapeUrl($this->getApproveOrderUrl()) ?>"
    data-method-code="<?= $this->escapeHtml($methodCode) ?>">
    <div id="paypal-card-fields-number" class="paypal-card-field"></div>
    <div class="paypal-card-row">
        <div id="paypal-card-fields-expiry" class="paypal-card-field"></div>
        <div id="paypal-card-fields-cvv" class="paypal-card-field"></div>
    </div>
    <div id="paypal-card-errors" class="validation-advice" style="display:none"></div>
    <?php if ($this->isVaultAvailable()): ?>
    <label class="paypal-save-vault" for="paypal_advanced_save_vault">
        <input type="checkbox" id="paypal_advanced_save_vault" name="payment[save_vault]" value="1">
        <span class="paypal-save-vault-icon"><?= Mage::helper('core')->getIconSvg('lock', 'outline') ?></span>
        <span><?= $this->escapeHtml($this->__('Save this payment method for future purchases')) ?></span>
    </label>
    <?php endif; ?>
</div>
