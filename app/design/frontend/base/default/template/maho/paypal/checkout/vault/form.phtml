/** @var Maho_Paypal_Block_Checkout_Vault_Form $this */
$tokens = $this->getCustomerTokens();
$methodCode = $this->getMethodCode();
?>
<div id="payment_form_<?= $this->escapeHtmlAttr($methodCode) ?>" style="display:none">
    <?php if ($tokens->getSize() > 0): ?>
    <div class="form-list">
        <label for="paypal_vault_token"><?= $this->escapeHtml($this->__('Select a saved payment method')) ?></label>
        <select name="payment[vault_token_id]" id="paypal_vault_token" class="required-entry">
            <option value=""><?= $this->escapeHtml($this->__('-- Please Select --')) ?></option>
            <?php foreach ($tokens as $token): ?>
            <option value="<?= $this->escapeHtmlAttr($token->getId()) ?>">
                <?= $this->escapeHtml($token->getDisplayLabel()) ?>
            </option>
            <?php endforeach; ?>
        </select>
    </div>
    <?php else: ?>
    <p><?= $this->escapeHtml($this->__('No saved payment methods available.')) ?></p>
    <?php endif; ?>
</div>
<script src="<?= $this->escapeUrl($this->getSkinUrl('js/maho/paypal/vault-checkout.js')) ?>"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const vaultCheckout = new MahoPaypalVaultCheckout({
        createOrderUrl: <?= Mage::helper('core')->jsonEncode($this->getCreateOrderUrl()) ?>,
        approveOrderUrl: <?= Mage::helper('core')->jsonEncode($this->getApproveOrderUrl()) ?>,
        methodCode: <?= Mage::helper('core')->jsonEncode($methodCode) ?>,
    });

    if (typeof payment !== 'undefined') {
        payment.addBeforeValidateFunc(<?= Mage::helper('core')->jsonEncode($methodCode) ?>, function() {
            return vaultCheckout.submit();
        });
    }
});
</script>
