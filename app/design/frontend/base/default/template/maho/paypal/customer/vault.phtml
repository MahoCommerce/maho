/** @var Maho_Paypal_Block_Customer_Vault $this */
$tokens = $this->getTokens();
?>
<div class="page-title">
    <h1><?= $this->escapeHtml($this->__('Saved Payment Methods')) ?></h1>
</div>

<?php if ($tokens->getSize() > 0): ?>
<table class="data-table" id="saved-payment-methods">
    <thead>
        <tr>
            <th><?= $this->escapeHtml($this->__('Payment Method')) ?></th>
            <th><?= $this->escapeHtml($this->__('Type')) ?></th>
            <th><?= $this->escapeHtml($this->__('Added')) ?></th>
            <th><?= $this->escapeHtml($this->__('Actions')) ?></th>
        </tr>
    </thead>
    <tbody>
        <?php foreach ($tokens as $token): ?>
        <tr>
            <td><?= $this->escapeHtml($token->getDisplayLabel()) ?></td>
            <td><?= $this->escapeHtml(ucfirst($token->getPaymentSourceType())) ?></td>
            <td><?= $this->escapeHtml(Mage::helper('core')->formatDate($token->getCreatedAt(), 'medium')) ?></td>
            <td>
                <form action="<?= $this->escapeUrl($this->getDeleteUrl((int) $token->getId())) ?>" method="post">
                    <?= $this->getBlockHtml('formkey') ?>
                    <button type="submit" class="link-remove"
                            onclick="return confirm('<?= $this->jsQuoteEscape($this->__('Are you sure you want to delete this payment method?')) ?>')"
                    ><?= $this->escapeHtml($this->__('Delete')) ?></button>
                </form>
            </td>
        </tr>
        <?php endforeach; ?>
    </tbody>
</table>
<?php else: ?>
<p class="empty"><?= $this->escapeHtml($this->__('You have no saved payment methods.')) ?></p>
<?php endif; ?>
