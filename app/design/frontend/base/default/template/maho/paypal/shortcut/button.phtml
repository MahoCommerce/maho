/** @var Maho_Paypal_Block_Shortcut_Button $this */
$containerId = $this->getShortcutHtmlId();
?>
<div id="<?= $this->escapeHtmlAttr($containerId) ?>" class="paypal-shortcut-button"></div>
<script src="<?= $this->escapeUrl($this->getJsSdkUrl()) ?>" data-namespace="paypalShortcut"></script>
<script src="<?= $this->escapeUrl($this->getSkinUrl('js/maho/paypal/standard-checkout.js')) ?>"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const paypalShortcut = new MahoPaypalStandardCheckout({
        createOrderUrl: <?= Mage::helper('core')->jsonEncode($this->getCreateOrderUrl()) ?>,
        approveOrderUrl: <?= Mage::helper('core')->jsonEncode($this->getApproveOrderUrl()) ?>,
        containerId: <?= Mage::helper('core')->jsonEncode($containerId) ?>,
    });
    paypalShortcut.mount();
});
</script>
