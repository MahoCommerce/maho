/** @var Maho_Paypal_Block_Checkout_Standard_Form $this */
$containerId = 'paypal-button-container-' . $this->getMethodCode();
?>
<div id="payment_form_<?= $this->escapeHtmlAttr($this->getMethodCode()) ?>" style="display:none">
    <div id="<?= $this->escapeHtmlAttr($containerId) ?>" class="paypal-button-container"></div>
</div>
<script src="<?= $this->escapeUrl($this->getJsSdkUrl()) ?>" data-namespace="paypal"></script>
<script src="<?= $this->escapeUrl($this->getSkinUrl('js/maho/paypal/standard-checkout.js')) ?>"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const paypalCheckout = new MahoPaypalStandardCheckout({
        createOrderUrl: <?= Mage::helper('core')->jsonEncode($this->getCreateOrderUrl()) ?>,
        approveOrderUrl: <?= Mage::helper('core')->jsonEncode($this->getApproveOrderUrl()) ?>,
        containerId: <?= Mage::helper('core')->jsonEncode($containerId) ?>,
        methodCode: <?= Mage::helper('core')->jsonEncode($this->getMethodCode()) ?>,
    });

    if (typeof payment !== 'undefined') {
        payment.addAfterInitFunction(<?= Mage::helper('core')->jsonEncode($this->getMethodCode()) ?>, function() {
            paypalCheckout.mount();
        });
    } else {
        paypalCheckout.mount();
    }
});
</script>
