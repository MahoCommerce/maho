/** @var Mage_Directory_Block_Currency $this */
?>
<?php if ($this->getCurrencyCount() > 1): ?>
<div class="currency-switcher">
    <label for="select-currency" class="visually-hidden"><?= $this->__('Your Currency:') ?></label>
    <?php /* Navigate directly: the option value is already a fully-encoded URL, and setLocation()'s encodeURI() would double-encode the uenc back-URL (%2C -> %252C). */ ?>
    <select id="select-currency" name="currency" title="<?= $this->quoteEscape($this->__('Your Currency')) ?>" onchange="window.location.href=this.value">
        <?php foreach ($this->getCurrencies() as $_code => $_name): ?>
        <option value="<?= $this->getSwitchCurrencyUrl($_code) ?>"<?php if($_code==$this->getCurrentCurrencyCode()): ?> selected="selected"<?php endif ?>>
            <?= Mage::app()->getLocale()->getCurrencySymbol($_code) ?>
        </option>
    <?php endforeach ?>
    </select>
</div>
<?php endif ?>
