/** @var Mage_CatalogSearch_Block_Result $this */
?>
<?php if($this->getResultCount()): ?>
<?= $this->getMessagesBlock()->toHtml() ?>
<div class="page-title">
    <?php if ($this->helper('rss/catalog')->getTagFeedUrl()): ?>
        <a href="<?= $this->helper('rss/catalog')->getTagFeedUrl() ?>" class="nobr link-rss"><?= $this->__('Subscribe to Feed') ?></a>
    <?php endif ?>
    <h1><?= ($this->getHeaderText() || $this->getHeaderText() === false) ? $this->getHeaderText() : $this->__("Search results for '%s'", $this->helper('catalogsearch')->getEscapedQueryText()) ?></h1>
</div>
    <?php if ($messages = $this->getNoteMessages()):?>
    <p class="note-msg">
        <?php foreach ($messages as $message):?>
            <?= $message ?><br>
        <?php endforeach ?>
    </p>
    <?php endif ?>
    <?= $this->getProductListHtml() ?>
<?php else: ?>
<div class="page-title">
    <h1><?= ($this->getHeaderText() || $this->getHeaderText() === false) ? $this->getHeaderText() : $this->__("Search results for '%s'", $this->helper('catalogsearch')->getEscapedQueryText()) ?></h1>
</div>
<p class="note-msg">
    <?= ($this->getNoResultText()) ? $this->getNoResultText() : $this->__('Your search returns no results.') ?>
    <?= $this->getAdditionalHtml() ?>
    <?php if ($messages = $this->getNoteMessages()):?>
        <?php foreach ($messages as $message):?>
        <br><?= $message ?>
        <?php endforeach ?>
    <?php endif ?>
</p>
<?php endif ?>
