/** @var Mage_Core_Block_Template $this */
$helper = Mage::helper('captcha');
if (!$helper->isEnabled()) return '';
?>
<altcha-widget <?= $helper->getWidgetAttributes()->serialize() ?>></altcha-widget>
<script src="<?= Mage::getBaseUrl('js') ?>maho-captcha.js" defer></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        MahoCaptcha.setup({
            frontendSelectors: '<?= $helper->getFrontendSelectors() ?>',
            widgetAttributes: <?= $helper->getWidgetAttributes()->toJson() ?>,
            loadingImageUrl: '<?= $this->getSkinUrl('images/loading.svg') ?>',
            verifyingText: '<?= $this->jsQuoteEscape($helper->__('Verifying...')) ?>'
        });
    });
</script>
