/** @var Mage_Catalog_Block_Layer_Filter_Attribute $this */
?>
<?php
$_seoHelper = $this->helper('catalog/category');
// The category (cat) filter is treated like any other facet: its links point to
// ?cat=<id> duplicate views, not the subcategory's canonical URL, so they get the
// same nofollow treatment. Subcategories stay crawlable via their own clean URLs.
$addNofollow = $_seoHelper->canUseNofollowForFilterLinks()
    && !$_seoHelper->isLayeredNavigationLandingPage();
?>
<ol>
<?php foreach ($this->getItems() as $_item): ?>
    <li>
        <?php if ($_item->getCount() > 0): ?>
            <a href="<?= $this->escapeUrl($_item->getUrl()) ?>"<?php if ($addNofollow): ?> rel="nofollow"<?php endif ?>>
                <?= $_item->getLabel() ?>
                <?php if ($this->shouldDisplayProductCount()): ?>
                <span class="count">(<?= $_item->getCount() ?>)</span>
                <?php endif ?>
            </a>
        <?php else: ?>
            <span>
                <?= $_item->getLabel() ?>
                <?php if ($this->shouldDisplayProductCount()): ?>
                    <span class="count">(<?= $_item->getCount() ?>)</span>
                <?php endif ?>
            </span>
        <?php endif ?>
    </li>
<?php endforeach ?>
</ol>
