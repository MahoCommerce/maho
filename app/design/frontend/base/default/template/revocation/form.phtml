/** @var Maho_Revocation_Block_Form $this */
$helper = Mage::helper('revocation');
$formData = $this->getFormData();
?>
<div class="revocation-form page-title">
    <h1><?= $helper->__('Revoke contract') ?></h1>
</div>
<p><?= $helper->__('You can revoke your contract within the statutory withdrawal period using this form. No account or login is required. After submitting, you will receive a confirmation that your declaration has been received.') ?></p>

<form action="<?= $this->getFormActionUrl() ?>" id="revocation-form" method="post" class="scaffold-form" autocomplete="on">
    <?= $this->getBlockHtml('formkey') ?>
    <input type="hidden" name="frt" value="<?= $this->escapeHtml($this->getRenderToken()) ?>">
    <?php if ($formData->getSessionOrderId()): ?>
        <input type="hidden" name="session_order_id" value="<?= (int) $formData->getSessionOrderId() ?>">
    <?php endif ?>
    <div class="revocation-hp" aria-hidden="true" style="position:absolute;left:-9999px;height:0;overflow:hidden;">
        <label for="comment_body"><?= $helper->__('Leave this field empty') ?></label>
        <input name="comment_body" id="comment_body" value="" type="text" tabindex="-1" autocomplete="off">
    </div>
    <div class="fieldset">
        <h2 class="legend"><?= $helper->__('I/we hereby revoke the contract concluded for the purchase of the following goods/services') ?></h2>
        <ul class="form-list">
            <li class="fields">
                <div class="field">
                    <label for="customer_name" class="required"><?= $helper->__('Name') ?></label>
                    <div class="input-box">
                        <input name="customer_name" id="customer_name" title="<?= $this->quoteEscape($helper->__('Name')) ?>" value="<?= $this->escapeHtml($formData->getCustomerName()) ?>" class="input-text required-entry" type="text" autocomplete="name">
                    </div>
                </div>
                <div class="field">
                    <label for="email" class="required"><?= $helper->__('Email') ?></label>
                    <div class="input-box">
                        <input name="email" id="email" title="<?= $this->quoteEscape($helper->__('Email')) ?>" value="<?= $this->escapeHtml($formData->getEmail()) ?>" class="input-text required-entry validate-email" type="email" autocomplete="email" autocapitalize="off" autocorrect="off" spellcheck="false">
                    </div>
                </div>
