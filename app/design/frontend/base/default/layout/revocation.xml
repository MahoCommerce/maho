<layout version="0.1.0">
    <revocation_index_index translate="label">
        <label>Revocation Form</label>
        <reference name="root">
            <action method="setTemplate"><template>page/2columns-left.phtml</template></action>
            <action method="setHeaderTitle" translate="title" module="revocation"><title>Revoke contract</title></action>
        </reference>
        <update handle="cms_menu"/>
        <reference name="content">
            <block type="revocation/form" name="revocation.form" template="revocation/form.phtml"/>
        </reference>
    </revocation_index_index>

    <revocation_index_success translate="label">
        <label>Revocation Success</label>
        <reference name="root">
            <action method="setTemplate"><template>page/2columns-left.phtml</template></action>
            <action method="setHeaderTitle" translate="title" module="revocation"><title>Revocation received</title></action>
        </reference>
        <update handle="cms_menu"/>
        <reference name="content">
            <block type="revocation/success" name="revocation.success" template="revocation/success.phtml"/>
        </reference>
    </revocation_index_success>

    <sales_order_view>
        <reference name="sales.order.info.buttons">
            <block type="revocation/order_link" name="revocation.order.link" template="revocation/order_link.phtml"/>
        </reference>
    </sales_order_view>
</layout>
