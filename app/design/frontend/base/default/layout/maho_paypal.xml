<layout>
    <checkout_onepage_index>
        <reference name="head">
            <action method="addJs" ifconfig="payment/paypal_standard_checkout/active"><script>maho/paypal/sdk-loader.js</script></action>
            <action method="addJs" ifconfig="payment/paypal_standard_checkout/active"><script>maho/paypal/standard-checkout.js</script></action>
            <action method="addJs" ifconfig="payment/paypal_advanced_checkout/active"><script>maho/paypal/sdk-loader.js</script></action>
            <action method="addJs" ifconfig="payment/paypal_advanced_checkout/active"><script>maho/paypal/advanced-checkout.js</script></action>
            <action method="addJs" ifconfig="payment/paypal_vault/active"><script>maho/paypal/vault-checkout.js</script></action>
        </reference>
        <reference name="checkout.payment.methods">
            <action method="setMethodFormTemplate">
                <method>paypal_standard_checkout</method>
                <template>maho/paypal/checkout/standard/form.phtml</template>
            </action>
            <action method="setMethodFormTemplate">
                <method>paypal_advanced_checkout</method>
                <template>maho/paypal/checkout/advanced/form.phtml</template>
            </action>
            <action method="setMethodFormTemplate">
                <method>paypal_vault</method>
                <template>maho/paypal/checkout/vault/form.phtml</template>
            </action>
        </reference>
    </checkout_onepage_index>

    <checkout_cart_index>
        <reference name="head">
            <action method="addJs" ifconfig="payment/paypal_standard_checkout/active"><script>maho/paypal/sdk-loader.js</script></action>
            <action method="addJs" ifconfig="payment/paypal_standard_checkout/active"><script>maho/paypal/standard-checkout.js</script></action>
            <action method="addJs" ifconfig="maho_paypal/general/paylater_messaging"><script>maho/paypal/sdk-loader.js</script></action>
            <action method="addJs" ifconfig="maho_paypal/general/paylater_messaging"><script>maho/paypal/paylater-message.js</script></action>
        </reference>
        <reference name="checkout.cart.methods">
            <block type="maho_paypal/shortcut_button" name="checkout.cart.methods.maho_paypal" template="maho/paypal/shortcut/button.phtml" ifconfig="payment/paypal_standard_checkout/active">
                <action method="setIsQuoteAllowed"><value>1</value></action>
            </block>
        </reference>
        <reference name="checkout.cart.totals">
            <block type="maho_paypal/paylater_message" name="checkout.cart.paylater" after="-" template="maho/paypal/paylater/message.phtml" ifconfig="maho_paypal/general/paylater_messaging">
                <action method="setIsQuoteAllowed"><value>1</value></action>
            </block>
        </reference>
    </checkout_cart_index>

    <catalog_product_view>
        <reference name="head">
            <action method="addJs" ifconfig="payment/paypal_standard_checkout/active"><script>maho/paypal/sdk-loader.js</script></action>
            <action method="addJs" ifconfig="payment/paypal_standard_checkout/active"><script>maho/paypal/standard-checkout.js</script></action>
            <action method="addJs" ifconfig="maho_paypal/general/paylater_messaging"><script>maho/paypal/sdk-loader.js</script></action>
            <action method="addJs" ifconfig="maho_paypal/general/paylater_messaging"><script>maho/paypal/paylater-message.js</script></action>
        </reference>
        <reference name="product.info.addtocart">
            <block type="maho_paypal/shortcut_button" name="product.info.addtocart.maho_paypal" template="maho/paypal/shortcut/button.phtml" ifconfig="payment/paypal_standard_checkout/active">
                <action method="setIsInCatalogProduct"><value>1</value></action>
            </block>
            <block type="maho_paypal/paylater_message" name="product.info.paylater" after="-" template="maho/paypal/paylater/message.phtml" ifconfig="maho_paypal/general/paylater_messaging">
                <action method="setIsInCatalogProduct"><value>1</value></action>
            </block>
        </reference>
    </catalog_product_view>

    <customer_account>
        <reference name="customer_account_navigation">
            <action method="addLink" ifconfig="payment/paypal_vault/active">
                <name>paypal_vault</name>
                <path>paypal/vault</path>
                <label>Saved Payment Methods</label>
            </action>
        </reference>
    </customer_account>

    <paypal_vault_index>
        <label>My Saved Payment Methods</label>
        <update handle="customer_account"/>
        <reference name="my.account.wrapper">
            <block type="maho_paypal/customer_vault" name="customer.paypal.vault" template="maho/paypal/customer/vault.phtml"/>
        </reference>
    </paypal_vault_index>
</layout>
