<config>
    <modules>
        <Maho_ShippingBridge>
            <version>1.0.0</version>
        </Maho_ShippingBridge>
    </modules>
    <global>
        <models>
            <shippingbridge>
                <class>Maho_ShippingBridge_Model</class>
            </shippingbridge>
        </models>
        <helpers>
            <shippingbridge>
                <class>Maho_ShippingBridge_Helper</class>
            </shippingbridge>
        </helpers>
    </global>
    <default>
        <carriers>
            <shippingbridge>
                <active>0</active>
                <model>shippingbridge/carrier</model>
                <title>Shipping Bridge</title>
                <api_url/>
                <auth_type>none</auth_type>
                <auth_token backend_model="adminhtml/system_config_backend_encrypted"/>
                <custom_header_name/>
                <timeout>10</timeout>
                <additional_attributes/>
                <debug>0</debug>
                <sort_order/>
                <sallowspecific>0</sallowspecific>
                <specificerrmsg>This shipping method is currently unavailable. If you would like to ship using this method, please contact us.</specificerrmsg>
            </shippingbridge>
        </carriers>
    </default>
</config>
