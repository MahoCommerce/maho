<config>
    <modules>
        <Maho_CustomerSegmentation>
            <version>1.1.0</version>
        </Maho_CustomerSegmentation>
    </modules>
    <global>
        <models>
            <customersegmentation>
                <class>Maho_CustomerSegmentation_Model</class>
                <resourceModel>customersegmentation_resource</resourceModel>
            </customersegmentation>
            <customersegmentation_resource>
                <class>Maho_CustomerSegmentation_Model_Resource</class>
                <entities>
                    <segment>
                        <table>customer_segment</table>
                    </segment>
                    <segment_customer>
                        <table>customer_segment_customer</table>
                    </segment_customer>
                    <emailSequence>
                        <table>customer_segment_email_sequence</table>
                    </emailSequence>
                    <sequenceProgress>
                        <table>customer_segment_sequence_progress</table>
                    </sequenceProgress>
                </entities>
            </customersegmentation_resource>
        </models>
        <resources>
            <customersegmentation_setup>
                <setup>
                    <module>Maho_CustomerSegmentation</module>
                    <class>Mage_Core_Model_Resource_Setup</class>
                </setup>
            </customersegmentation_setup>
            <customersegmentation_resource>
                <connection>
                    <use>core_setup</use>
                </connection>
            </customersegmentation_resource>
        </resources>
        <blocks>
            <customersegmentation>
                <class>Maho_CustomerSegmentation_Block</class>
            </customersegmentation>
        </blocks>
        <helpers>
            <customersegmentation>
                <class>Maho_CustomerSegmentation_Helper</class>
            </customersegmentation>
        </helpers>
    </global>
    <adminhtml>
        <layout>
            <updates>
                <customersegmentation>
                    <file>customersegmentation.xml</file>
                </customersegmentation>
            </updates>
        </layout>
        <translate>
            <modules>
                <Maho_CustomerSegmentation>
                    <files>
                        <default>Maho_CustomerSegmentation.csv</default>
                    </files>
                </Maho_CustomerSegmentation>
            </modules>
        </translate>
    </adminhtml>
    <default>
        <customer>
            <customer_segments>
                <cron_schedule>0 5 * * *</cron_schedule>
            </customer_segments>
        </customer>
        <customer_segmentation>
            <email_automation>
                <enabled>1</enabled>
                <cleanup_days>90</cleanup_days>
                <coupon_cleanup_days>30</coupon_cleanup_days>
            </email_automation>
        </customer_segmentation>
    </default>
</config>
