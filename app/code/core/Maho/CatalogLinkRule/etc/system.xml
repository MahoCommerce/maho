<config>
    <sections>
        <catalog>
            <groups>
                <linkrule translate="label" module="cataloglinkrule">
                    <label>Product Link Rules</label>
                    <sort_order>500</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>0</show_in_website>
                    <show_in_store>0</show_in_store>
                    <fields>
                        <schedule translate="label comment">
                            <label>Cron Schedule</label>
                            <comment><![CDATA[Cron expression for rule processing. Default: <strong>0 3 * * *</strong> (daily at 3am).]]></comment>
                            <frontend_type>text</frontend_type>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </schedule>
                        <merge_mode translate="label comment">
                            <label>Merge Behaviour</label>
                            <comment><![CDATA[How rule-generated links combine with existing product links.<br/><strong>Replace</strong>: delete existing links, then insert rule results (default).<br/><strong>Merge</strong>: keep existing links and append rule results, with no duplicates.]]></comment>
                            <frontend_type>select</frontend_type>
                            <source_model>cataloglinkrule/system_config_source_mergeMode</source_model>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </merge_mode>
                    </fields>
                </linkrule>
            </groups>
        </catalog>
    </sections>
</config>
