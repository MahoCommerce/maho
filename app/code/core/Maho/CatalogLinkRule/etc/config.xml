<config>
    <modules>
        <Maho_CatalogLinkRule>
            <version>1.1.0</version>
        </Maho_CatalogLinkRule>
    </modules>

    <global>
        <models>
            <cataloglinkrule>
                <class>Maho_CatalogLinkRule_Model</class>
                <resourceModel>cataloglinkrule_resource</resourceModel>
            </cataloglinkrule>
            <cataloglinkrule_resource>
                <class>Maho_CatalogLinkRule_Model_Resource</class>
                <entities>
                    <rule>
                        <table>catalog_product_link_rule</table>
                    </rule>
                </entities>
            </cataloglinkrule_resource>
        </models>

        <helpers>
            <cataloglinkrule>
                <class>Maho_CatalogLinkRule_Helper</class>
            </cataloglinkrule>
        </helpers>

        <blocks>
            <cataloglinkrule>
                <class>Maho_CatalogLinkRule_Block</class>
            </cataloglinkrule>
        </blocks>
    </global>

    <adminhtml>
        <layout>
            <updates>
                <cataloglinkrule>
                    <file>cataloglinkrule.xml</file>
                </cataloglinkrule>
            </updates>
        </layout>
        <translate>
            <modules>
                <Maho_CatalogLinkRule>
                    <files>
                        <default>Maho_CatalogLinkRule.csv</default>
                    </files>
                </Maho_CatalogLinkRule>
            </modules>
        </translate>
    </adminhtml>

    <default>
        <catalog>
            <linkrule>
                <schedule>0 3 * * *</schedule>
                <merge_mode>replace</merge_mode>
            </linkrule>
        </catalog>
    </default>

</config>
