<config>
    <sections>
        <catalog>
            <groups>
                <structured_data translate="label comment" module="structureddata">
                    <label>Structured Data (schema.org)</label>
                    <comment><![CDATA[Outputs <strong>JSON-LD structured data</strong> following schema.org and Google's requirements, enabling rich results for products, breadcrumbs, organization info and site search. Validate your pages with the <a href="https://search.google.com/test/rich-results" target="_blank">Google Rich Results Test</a>.]]></comment>
                    <frontend_type>text</frontend_type>
                    <sort_order>400</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Enable Structured Data</label>
                            <frontend_type>boolean</frontend_type>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>

                        <product_heading translate="label">
                            <label>Product Schema</label>
                            <frontend_model>adminhtml/system_config_form_field_heading</frontend_model>
                            <sort_order>100</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled></depends>
                        </product_heading>
                        <product_enabled translate="label">
                            <label>Enable Product Schema</label>
                            <config_path>catalog/structured_data/product/enabled</config_path>
                            <frontend_type>boolean</frontend_type>
                            <sort_order>110</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled></depends>
                        </product_enabled>
                        <product_include_reviews translate="label comment">
                            <label>Include Ratings &amp; Reviews</label>
                            <comment>Adds aggregateRating (rating value and review count) to the product schema when reviews are enabled.</comment>
                            <config_path>catalog/structured_data/product/include_reviews</config_path>
                            <frontend_type>boolean</frontend_type>
                            <sort_order>120</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><product_enabled>1</product_enabled></depends>
                        </product_include_reviews>
                        <product_brand_attribute translate="label comment">
                            <label>Brand Attribute</label>
                            <comment>Product attribute used for the schema.org "brand" property.</comment>
                            <config_path>catalog/structured_data/product/brand_attribute</config_path>
                            <frontend_type>select</frontend_type>
                            <source_model>structureddata/system_config_source_product_attribute</source_model>
                            <sort_order>130</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><product_enabled>1</product_enabled></depends>
                        </product_brand_attribute>
                        <product_gtin_attribute translate="label comment">
                            <label>GTIN Attribute</label>
                            <comment>Product attribute holding the Global Trade Item Number (UPC/EAN/ISBN).</comment>
                            <config_path>catalog/structured_data/product/gtin_attribute</config_path>
                            <frontend_type>select</frontend_type>
                            <source_model>structureddata/system_config_source_product_attribute</source_model>
                            <sort_order>140</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><product_enabled>1</product_enabled></depends>
                        </product_gtin_attribute>
                        <product_mpn_attribute translate="label comment">
                            <label>MPN Attribute</label>
                            <comment>Product attribute holding the Manufacturer Part Number.</comment>
                            <config_path>catalog/structured_data/product/mpn_attribute</config_path>
                            <frontend_type>select</frontend_type>
                            <source_model>structureddata/system_config_source_product_attribute</source_model>
                            <sort_order>150</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><product_enabled>1</product_enabled></depends>
                        </product_mpn_attribute>
                        <product_low_stock_threshold translate="label comment">
                            <label>Low Stock Threshold</label>
                            <comment>When the saleable quantity is at or below this value, availability is reported as LimitedAvailability. Set to 0 to disable.</comment>
                            <config_path>catalog/structured_data/product/low_stock_threshold</config_path>
                            <frontend_type>text</frontend_type>
                            <validate>validate-digits</validate>
                            <sort_order>160</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><product_enabled>1</product_enabled></depends>
                        </product_low_stock_threshold>

                        <breadcrumbs_heading translate="label">
                            <label>Breadcrumbs Schema</label>
                            <frontend_model>adminhtml/system_config_form_field_heading</frontend_model>
                            <sort_order>200</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled></depends>
                        </breadcrumbs_heading>
                        <breadcrumbs_enabled translate="label">
                            <label>Enable BreadcrumbList Schema</label>
                            <config_path>catalog/structured_data/breadcrumbs/enabled</config_path>
                            <frontend_type>boolean</frontend_type>
                            <sort_order>210</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled></depends>
                        </breadcrumbs_enabled>

                        <organization_heading translate="label">
                            <label>Organization Schema</label>
                            <frontend_model>adminhtml/system_config_form_field_heading</frontend_model>
                            <sort_order>300</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled></depends>
                        </organization_heading>
                        <organization_enabled translate="label">
                            <label>Enable Organization Schema</label>
                            <config_path>catalog/structured_data/organization/enabled</config_path>
                            <frontend_type>boolean</frontend_type>
                            <sort_order>310</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled></depends>
                        </organization_enabled>
                        <organization_type translate="label comment">
                            <label>Organization Type</label>
                            <comment>The schema.org @type used for the organization. Use Local Business to include the store address.</comment>
                            <config_path>catalog/structured_data/organization/type</config_path>
                            <frontend_type>select</frontend_type>
                            <source_model>structureddata/system_config_source_organization_type</source_model>
                            <sort_order>320</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><organization_enabled>1</organization_enabled></depends>
                        </organization_type>
                        <organization_logo_url translate="label comment">
                            <label>Logo URL</label>
                            <comment>Absolute URL to the organization logo. Leave empty to use the store logo.</comment>
                            <config_path>catalog/structured_data/organization/logo_url</config_path>
                            <frontend_type>text</frontend_type>
                            <sort_order>330</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><organization_enabled>1</organization_enabled></depends>
                        </organization_logo_url>
                        <organization_contact_phone translate="label comment">
                            <label>Contact Phone</label>
                            <comment>Customer service telephone number. Leave empty to use the store information phone.</comment>
                            <config_path>catalog/structured_data/organization/contact_phone</config_path>
                            <frontend_type>text</frontend_type>
                            <sort_order>340</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><organization_enabled>1</organization_enabled></depends>
                        </organization_contact_phone>
                        <organization_contact_email translate="label comment">
                            <label>Contact Email</label>
                            <comment>Customer service email address (optional).</comment>
                            <config_path>catalog/structured_data/organization/contact_email</config_path>
                            <frontend_type>text</frontend_type>
                            <sort_order>350</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><organization_enabled>1</organization_enabled></depends>
                        </organization_contact_email>
                        <organization_facebook_url translate="label">
                            <label>Facebook URL</label>
                            <config_path>catalog/structured_data/organization/facebook_url</config_path>
                            <frontend_type>text</frontend_type>
                            <sort_order>360</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><organization_enabled>1</organization_enabled></depends>
                        </organization_facebook_url>
                        <organization_twitter_url translate="label">
                            <label>X (Twitter) URL</label>
                            <config_path>catalog/structured_data/organization/twitter_url</config_path>
                            <frontend_type>text</frontend_type>
                            <sort_order>370</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><organization_enabled>1</organization_enabled></depends>
                        </organization_twitter_url>
                        <organization_instagram_url translate="label">
                            <label>Instagram URL</label>
                            <config_path>catalog/structured_data/organization/instagram_url</config_path>
                            <frontend_type>text</frontend_type>
                            <sort_order>380</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><organization_enabled>1</organization_enabled></depends>
                        </organization_instagram_url>
                        <organization_linkedin_url translate="label">
                            <label>LinkedIn URL</label>
                            <config_path>catalog/structured_data/organization/linkedin_url</config_path>
                            <frontend_type>text</frontend_type>
                            <sort_order>390</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled><organization_enabled>1</organization_enabled></depends>
                        </organization_linkedin_url>

                        <website_heading translate="label">
                            <label>Website Schema</label>
                            <frontend_model>adminhtml/system_config_form_field_heading</frontend_model>
                            <sort_order>400</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled></depends>
                        </website_heading>
                        <website_enabled translate="label comment">
                            <label>Enable WebSite Schema</label>
                            <comment>Outputs WebSite schema with a SearchAction so search engines can offer a sitelinks search box.</comment>
                            <config_path>catalog/structured_data/website/enabled</config_path>
                            <frontend_type>boolean</frontend_type>
                            <sort_order>410</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <depends><enabled>1</enabled></depends>
                        </website_enabled>
                    </fields>
                </structured_data>
            </groups>
        </catalog>
    </sections>
</config>
