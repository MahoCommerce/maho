<config>
    <modules>
        <Maho_StructuredData>
            <version>1.0.0</version>
        </Maho_StructuredData>
    </modules>
    <global>
        <blocks>
            <structureddata>
                <class>Maho_StructuredData_Block</class>
            </structureddata>
        </blocks>
        <helpers>
            <structureddata>
                <class>Maho_StructuredData_Helper</class>
            </structureddata>
        </helpers>
        <models>
            <structureddata>
                <class>Maho_StructuredData_Model</class>
            </structureddata>
        </models>
        <translate>
            <modules>
                <Maho_StructuredData>
                    <files>
                        <default>Maho_StructuredData.csv</default>
                    </files>
                </Maho_StructuredData>
            </modules>
        </translate>
    </global>
    <frontend>
        <layout>
            <updates>
                <structureddata>
                    <file>structureddata.xml</file>
                </structureddata>
            </updates>
        </layout>
    </frontend>
    <default>
        <catalog>
            <structured_data>
                <enabled>1</enabled>
                <product>
                    <enabled>1</enabled>
                    <include_reviews>1</include_reviews>
                    <brand_attribute>manufacturer</brand_attribute>
                    <gtin_attribute></gtin_attribute>
                    <mpn_attribute></mpn_attribute>
                    <low_stock_threshold>0</low_stock_threshold>
                </product>
                <breadcrumbs>
                    <enabled>1</enabled>
                </breadcrumbs>
                <organization>
                    <enabled>1</enabled>
                    <type>Organization</type>
                    <logo_url></logo_url>
                    <contact_phone></contact_phone>
                    <contact_email></contact_email>
                    <facebook_url></facebook_url>
                    <twitter_url></twitter_url>
                    <instagram_url></instagram_url>
                    <linkedin_url></linkedin_url>
                </organization>
                <website>
                    <enabled>1</enabled>
                </website>
            </structured_data>
        </catalog>
    </default>
</config>
