<config>
    <modules>
        <Maho_StructuredData>
            <version>1.0.0</version>
        </Maho_StructuredData>
    </modules>
    <global>
        <blocks>
            <structureddata>
                <class>Maho_StructuredData_Block</class>
            </structureddata>
        </blocks>
        <helpers>
            <structureddata>
                <class>Maho_StructuredData_Helper</class>
            </structureddata>
        </helpers>
        <models>
            <structureddata>
                <class>Maho_StructuredData_Model</class>
            </structureddata>
        </models>
        <translate>
            <modules>
                <Maho_StructuredData>
                    <files>
                        <default>Maho_StructuredData.csv</default>
                    </files>
                </Maho_StructuredData>
            </modules>
        </translate>
    </global>
    <frontend>
        <layout>
            <updates>
                <structureddata>
                    <file>structureddata.xml</file>
                </structureddata>
            </updates>
        </layout>
    </frontend>
    <default>
        <catalog>
            <structured_data>
                <enabled>1</enabled>
                <product>
                    <enabled>1</enabled>
                    <include_reviews>1</include_reviews>
                    <brand_attribute>manufacturer</brand_attribute>
                    <gtin_attribute>gtin</gtin_attribute>
                    <mpn_attribute>mpn</mpn_attribute>
                </product>
                <breadcrumbs>
                    <enabled>1</enabled>
                </breadcrumbs>
                <productlist>
                    <enabled>1</enabled>
                </productlist>
                <organization>
                    <enabled>1</enabled>
                    <type>Organization</type>
                    <contact_email></contact_email>
                </organization>
                <website>
                    <enabled>1</enabled>
                </website>
                <blog>
                    <enabled>1</enabled>
                </blog>
            </structured_data>
        </catalog>
    </default>
</config>
