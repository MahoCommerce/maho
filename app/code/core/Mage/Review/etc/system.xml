<config>
   <sections>
        <catalog>
            <groups>
                <review translate="label" module="review">
                    <label>Product Reviews</label>
                    <sort_order>100</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>0</show_in_store>
                    <fields>
                        <allow_guest translate="label">
                            <label>Allow Guests to Write Reviews</label>
                            <frontend_type>boolean</frontend_type>
                            <sort_order>1</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                        </allow_guest>
                    </fields>
                </review>
            </groups>
        </catalog>
        <system>
            <groups>
                <rate_limit>
                    <fields>
                        <review_submit translate="label comment" module="review">
                            <label>Review submit</label>
                            <comment>Per IP address. Default 5 per hour. 0 to disable.</comment>
                            <sort_order>170</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <validate>validate-digits validate-zero-or-greater</validate>
                        </review_submit>
                    </fields>
                </rate_limit>
            </groups>
        </system>
    </sections>
</config>
