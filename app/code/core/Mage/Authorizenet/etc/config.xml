<config>
    <modules>
        <Mage_Authorizenet>
            <version>1.5.0.0</version>
        </Mage_Authorizenet>
    </modules>
    <global>
        <models>
            <authorizenet>
                <class>Mage_Authorizenet_Model</class>
           </authorizenet>
        </models>
        <helpers>
            <authorizenet>
                <class>Mage_Authorizenet_Helper</class>
            </authorizenet>
        </helpers>
    </global>

    <adminhtml>
        <translate>
            <modules>
                <Mage_Authorizenet>
                    <files>
                        <default>Mage_Authorizenet.csv</default>
                    </files>
                </Mage_Authorizenet>
            </modules>
        </translate>
        <layout>
            <updates>
                <authorizenet>
                    <file>authorizenet.xml</file>
                </authorizenet>
            </updates>
        </layout>
    </adminhtml>

    <frontend>
        <translate>
            <modules>
                <Mage_Authorizenet>
                    <files>
                        <default>Mage_Authorizenet.csv</default>
                    </files>
                </Mage_Authorizenet>
            </modules>
        </translate>
        <layout>
            <updates>
                <authorizenet>
                    <file>authorizenet.xml</file>
                </authorizenet>
            </updates>
        </layout>
    </frontend>
</config>
