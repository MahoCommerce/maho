<config>
    <modules>
        <Mage_GoogleAnalytics>
            <version>2.0.0</version>
        </Mage_GoogleAnalytics>
    </modules>
    <global>
        <models>
            <googleanalytics>
                <class>Mage_GoogleAnalytics_Model</class>
            </googleanalytics>
        </models>
        <blocks>
            <googleanalytics>
                <class>Mage_GoogleAnalytics_Block</class>
            </googleanalytics>
        </blocks>
        <helpers>
            <googleanalytics>
                <class>Mage_GoogleAnalytics_Helper</class>
            </googleanalytics>
        </helpers>
    </global>
    <frontend>
        <translate>
            <modules>
                <Mage_GoogleAnalytics>
                    <files>
                        <default>Mage_GoogleAnalytics.csv</default>
                    </files>
                </Mage_GoogleAnalytics>
            </modules>
        </translate>
        <layout>
            <updates>
                <googleanalytics>
                    <file>googleanalytics.xml</file>
                </googleanalytics>
            </updates>
        </layout>
    </frontend>
    <adminhtml>
        <translate>
            <modules>
                <Mage_GoogleAnalytics>
                    <files>
                        <default>Mage_GoogleAnalytics.csv</default>
                    </files>
                </Mage_GoogleAnalytics>
            </modules>
        </translate>
    </adminhtml>
</config>
