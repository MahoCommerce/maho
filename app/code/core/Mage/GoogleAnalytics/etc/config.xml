<config>
    <modules>
        <Mage_GoogleAnalytics>
            <version>1.6.0.0</version>
        </Mage_GoogleAnalytics>
    </modules>
    <global>
        <models>
            <googleanalytics>
                <class>Mage_GoogleAnalytics_Model</class>
            </googleanalytics>
        </models>
        <blocks>
            <googleanalytics>
                <class>Mage_GoogleAnalytics_Block</class>
            </googleanalytics>
        </blocks>
        <helpers>
            <googleanalytics>
                <class>Mage_GoogleAnalytics_Helper</class>
            </googleanalytics>
        </helpers>
        <resources>
            <googleanalytics_setup>
                <setup>
                    <module>Mage_GoogleAnalytics</module>
                    <class>Mage_Core_Model_Resource_Setup</class>
                </setup>
            </googleanalytics_setup>
        </resources>
    </global>
    <frontend>
        <translate>
            <modules>
                <Mage_GoogleAnalytics>
                    <files>
                        <default>Mage_GoogleAnalytics.csv</default>
                    </files>
                </Mage_GoogleAnalytics>
            </modules>
        </translate>
        <layout>
            <updates>
                <googleanalytics>
                    <file>googleanalytics.xml</file>
                </googleanalytics>
            </updates>
        </layout>
    </frontend>
    <admin>
        <translate>
            <modules>
                <Mage_GoogleAnalytics>
                    <files>
                        <default>Mage_GoogleAnalytics.csv</default>
                    </files>
                </Mage_GoogleAnalytics>
            </modules>
        </translate>
    </admin>
</config>
