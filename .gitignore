# IDEs
.idea
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix
.planning/

# Maho stuff
/app/etc/local.xml*
!/app/etc/local.xml.template

/public/media/*
!/public/media/.htaccess
!/public/media/custom_options/.htaccess
!/public/media/customer/.htaccess
!/public/media/dhl/logo.jpg
!/public/media/downloadable/.htaccess

# Symfony bundle assets published by maho-composer-plugin (api-platform Swagger UI, etc.)
/public/bundles/

/var/*
!/var/.htaccess

# Composer
/vendor

# Local scripts with credentials
/shell/cf-purge.sh

# PHP-CS-Fixer
.php-cs-fixer.cache

# PHPStan
.phpstan.cache
.phpstan*.neon
phpstan*.neon
!.phpstan.dist*.neon

# Node / Playwright (browser tests): generated locally and in CI, never committed
/node_modules
/package.json
/package-lock.json
/.playwright
/.playwright-cli
/test-results
/tests/Browser/Screenshots

# Local secrets (e.g. PayPal sandbox creds for browser tests), never commit
.env
.env.*
!.env.testing.dist
